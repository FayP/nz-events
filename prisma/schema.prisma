// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  RUNNING
  BIKING
  TRIATHLON
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventSource {
  AI_GENERATED
  MANUAL
  SCRAPED
}

model Event {
  id                     String        @id @default(cuid())
  name                   String
  slug                   String        @unique
  description            String?       @db.Text
  eventType              EventType
  startDate              DateTime
  endDate                DateTime?
  registrationOpenDate   DateTime?
  registrationCloseDate  DateTime?
  location               String
  city                   String
  region                 String
  latitude               Float?
  longitude              Float?
  website                String?
  registrationUrl        String?
  organizer              String?
  organizerEmail         String?
  organizerWebsite       String?
  distances              Json? // Array of distances, e.g. ["5K", "10K", "Half Marathon"]
  distanceDetails        Json? // Enhanced distance info [{ name, distance, elevation, time, description }]
  price                  Json? // Price information
  images                 Json? // Array of image URLs
  schedule               Json? // Race day schedule [{ time: "5:00 AM", description: "Transition opens" }]
  highlights             String[]      @default([]) // Event highlights
  courseTerrain          String? // e.g., "Rolling Hills", "Flat", "Mountainous"
  courseSurface          String? // e.g., "Sealed Roads", "Trail", "Mixed"
  courseTraffic          String? // e.g., "Full Closure", "Partial Closure", "Open Roads"
  cutoffTime             String? // e.g., "6.5 hours", "No cutoff"
  requirements           String[]      @default([]) // Equipment requirements
  inclusions             String[]      @default([]) // What's included with entry (e.g., "Race t-shirt", "Finisher medal")
  registrationCapacity   Int? // Total spots available
  registrationTaken      Int? // Spots already filled
  fullAddress            String? // Complete street address
  featured               Boolean       @default(false)
  verified               Boolean       @default(false)
  status                 EventStatus   @default(DRAFT)
  source                 EventSource   @default(MANUAL)
  seoTitle               String?
  seoDescription         String?
  previousSlugs          String[]      @default([])
  tags                   String[]      @default([])
  indexedInElasticsearch Boolean       @default(false)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  content                EventContent?

  @@index([eventType])
  @@index([region])
  @@index([city])
  @@index([startDate])
  @@index([status])
  @@index([slug])
  @@index([status, startDate])          // hot path: published events sorted by date
  @@index([status, eventType, startDate]) // hot path: filtered by type
}

model EventContent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content   Json // Rich text content from CMS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}