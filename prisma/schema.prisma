// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  RUNNING
  BIKING
  TRIATHLON
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventSource {
  AI_GENERATED
  MANUAL
  SCRAPED
}

model Event {
  id                  String      @id @default(cuid())
  name                String
  slug                String      @unique
  description         String?     @db.Text
  eventType           EventType
  startDate           DateTime
  endDate             DateTime?
  registrationOpenDate DateTime?
  registrationCloseDate DateTime?
  location            String
  city                String
  region              String
  latitude            Float?
  longitude           Float?
  website             String?
  registrationUrl     String?
  organizer           String?
  organizerEmail      String?
  distances           Json?       // Array of distances, e.g. ["5K", "10K", "Half Marathon"]
  price               Json?       // Price information
  images              Json?       // Array of image URLs
  featured            Boolean     @default(false)
  verified            Boolean     @default(false)
  status              EventStatus @default(DRAFT)
  source              EventSource @default(MANUAL)
  seoTitle            String?
  seoDescription      String?
  tags                String[]    @default([])
  indexedInElasticsearch Boolean  @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  content             EventContent?

  @@index([eventType])
  @@index([region])
  @@index([city])
  @@index([startDate])
  @@index([status])
  @@index([slug])
}

model EventContent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content     Json     // Rich text content from CMS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
